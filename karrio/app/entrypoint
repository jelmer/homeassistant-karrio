#!/bin/bash
# Karrio API startup shim. Runs Django migrations, seeds the superuser
# if there are no users yet, then launches gunicorn. Lifted from karrio's
# upstream docker/api/entrypoint.
set -e

karrio migrate
karrio collectstatic --noinput >/dev/null

karrio shell <<'PY'
from decouple import config
from django.contrib.auth import get_user_model
User = get_user_model()
if not User.objects.exists():
    User.objects.create_superuser(
        config("ADMIN_EMAIL", default="admin@example.com"),
        config("ADMIN_PASSWORD", default="demo"),
    )
PY

exec gunicorn --config gunicorn-cfg.py karrio.server.asgi \
    -k karrio.server.workers.UvicornWorker
